# OpenAI
OPENAI_API_KEY=sk-replace-me
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Vector store
VECTOR_STORE_BACKEND=chroma
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION=rag_documents
# Set CHROMA_HOST to use a remote Chroma server (e.g. docker-compose).
# When unset, the API runs Chroma embedded against CHROMA_PERSIST_DIR.
# CHROMA_HOST=chroma
# CHROMA_PORT=8000

# Ingestion
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# Retrieval
RETRIEVAL_TOP_K=4
RETRIEVAL_SCORE_THRESHOLD=0.0

# Generation
PROMPT_TEMPLATE_VERSION=v1
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=512

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
